# Recommended LLM provider. DeepSeek is the default.
LLM_PROVIDER=deepseek

# Required when MOCK_MODE=false and LLM_PROVIDER=deepseek.
DEEPSEEK_API_KEY=TODO_your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional OpenAI-compatible fallback. Only used when LLM_PROVIDER=openai.
OPENAI_API_KEY=TODO_your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# PushPlus token. Do not commit your real token.
PUSHPLUS_TOKEN=TODO_your_pushplus_token

# Optional: use mock news data for local visual testing. GitHub Actions sets this to false.
MOCK_MODE=true

# Optional: comma-separated or multi-line RSS URLs.
# Leave empty to use these same built-in 18 mixed RSS sources.
NEWS_RSS_URLS=https://news.google.com/rss/search?q=OpenAI&hl=zh-CN&gl=CN&ceid=CN:zh-Hans,https://news.google.com/rss/search?q=DeepSeek&hl=zh-CN&gl=CN&ceid=CN:zh-Hans,https://news.google.com/rss/search?q=NVIDIA&hl=zh-CN&gl=CN&ceid=CN:zh-Hans,https://news.google.com/rss/search?q=Tesla&hl=zh-CN&gl=CN&ceid=CN:zh-Hans,https://news.google.com/rss/search?q=Nasdaq&hl=zh-CN&gl=CN&ceid=CN:zh-Hans,https://news.google.com/rss/search?q=AI%20regulation&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=OpenAI&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=NVIDIA&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=Tesla&hl=en-US&gl=US&ceid=US:en,https://www.theverge.com/rss/index.xml,https://techcrunch.com/feed/,https://arstechnica.com/feed/,https://news.mit.edu/rss/feed,https://www.nasa.gov/news-release/feed/,https://www.federalreserve.gov/feeds/press_all.xml,https://www.sec.gov/news/pressreleases.rss,http://newsrss.bbc.co.uk/rss/newsonline_uk_edition/front_page/rss.xml,https://www.lemonde.fr/en/rss_full.xml

# Optional: comma-separated keywords for Google News RSS fallback.
NEWS_KEYWORDS=AI,人工智能,大模型,芯片,科技,金融市场,宏观经济

# Fixed lookback window and maximum generated cards.
NEWS_LOOKBACK_HOURS=2
MAX_NEWS_CARDS=12

# Required when pushing real images. For GitHub Actions, GitHub Pages is recommended.
# Example: https://YOUR_USERNAME.github.io/YOUR_REPO/cards
PUBLIC_BASE_URL=TODO_https_image_base_url

# Optional. Default is ./public/cards
PUBLIC_OUTPUT_DIR=public/cards

# Optional. Files here are bundled into the PWA and deployed to GitHub Pages.
WEB_PUBLIC_CARDS_DIR=web/public/cards

# Optional. Leave false until you are ready to send WeChat messages.
ENABLE_PUSH=false

# Optional. Used only by npm run test:pushplus.
# Must be an HTTPS image URL if you want the test message to include an image.
TEST_IMAGE_URL=
